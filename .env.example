# === Required (Sprint 1) ===
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=

# === Optional (Sprint 1) ===
GITHUB_TOKEN=

# === LLM Config ===
AGENT_MODEL=claude-opus-4-5
FAST_MODEL=claude-haiku-4-5
THINKING_BUDGET_DEFAULT=medium
THINKING_BUDGET_PREMIUM=high
THINKING_BUDGET_FAST=low

# === RAG Config ===
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=8

# === Limits ===
MAX_LOC=500000
AGENT_TIMEOUT_SECONDS=1200

# === Phase 2 (not needed for Sprint 1) ===
DATABASE_URL=postgresql+asyncpg://archon:archon@localhost:5432/archon
REDIS_URL=redis://localhost:6379
CLERK_SECRET_KEY=
STRIPE_SECRET_KEY=
